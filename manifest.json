{
  "manifest_version": 3,
  "name": "LexiTranslate - 划词翻译助手",
  "description": "划词即时翻译：多引擎回退、朗读与复制，支持快捷键与主题。",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://api.mymemory.translated.net/*",
    "https://libretranslate.de/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/constants.js",
        "src/settings.js",
        "src/translation.js",
        "src/content.js"
      ],
      "css": [
        "src/styles/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options/options.html",
  "commands": {
    "quick-translate": {
      "suggested_key": {
        "default": "Ctrl+Shift+T",
        "mac": "Command+Shift+T"
      },
      "description": "翻译当前选中的文本"
    }
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  }
}
